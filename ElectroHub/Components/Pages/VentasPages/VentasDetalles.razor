@page "/Ventas/Detalles/{VentaId:int}";

@rendermode InteractiveServer
@inject VentasService ventasServices;
@inject ProductosService productosService;
@inject NavigationManager navigationManager;

<PageTitle>VentasDetalles</PageTitle>

<div class="container">
    <label class="titulo">Detalles de venta</label>
    <hr />

    @* Tabla de productos *@
    <div class="table-responsive gradient-border-transparent">
        <table>
            <thead>
                <tr>
                    <th>C&oacute;digo</th>
                    <th>Descripci&oacute;n</th>
                    <th>Categor&iacute;a</th>
                    <th>Cantidad</th>
                    <th>Precio</th>
                    <th>ITBIS</th>
                    <th>Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var detalle in Venta.DetallesVentas)
                {
                    <tr>
                        <td>@detalle.ProductoId</td>
                        <td>@detalle.Descripcion</td>
                        <td>@detalle.Categoria.Nombre</td>
                        <td>@detalle.Cantidad</td>
                        <td>$@detalle.Precio</td>
                        <td>$@detalle.Itbis</td>
                        <td>$@detalle.Subtotal</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="neon-card neon-box-style mt-3">
        <label class="titulo">Detalle</label>

        @* Fecha y subtotal *@
        <div class="row align-items-center pb-3">
            <div class="col-3">
                <label class="subtitulo-detalle">Fecha:</label>
            </div>
            <div class="col-3">
                <label class="texto-detalle">@Venta.Fecha</label>
            </div>

            <div class="col-3">
                <label class="subtitulo-detalle">Subtotal:</label>
            </div>
            <div class="col-3">
                <label class="texto-detalle">$@Venta.Subtotal.ToString("N2")</label>
            </div>
        </div>

        @* Vendedor y descuento aplicado *@
        <div class="row align-items-center pb-3">
            <div class="col-3">
                <label class="subtitulo-detalle">Vendedor:</label>
            </div>
            <div class="col-3">
                <label class="texto-detalle">@Venta.Vendedor</label>
            </div>
            <div class="col-3">
                <label class="subtitulo-detalle">Desc. Aplicado:</label>
            </div>
            <div class="col-3">
                <label class="texto-detalle">$@Venta.DescuentoAplicado.ToString("N2")</label>
            </div>
        </div>

        @* Descuento y ITBIS *@
        <div class="row align-items-center pb-3">
            <div class="col-3">
                <label class="subtitulo-detalle">Descuento:</label>
            </div>
            <div class="col-3">
                <label class="texto-detalle">@Venta.Descuento %</label>
            </div>
            <div class="col-3">
                <label class="subtitulo-detalle">ITBIS:</label>
            </div>
            <div class="col-3">
                <label class="texto-detalle">$@Venta.Itbis.ToString("N2")</label>
            </div>
        </div>

        @* Metodo de pago y Total *@
        <div class="row align-items-center pb-3">
            <div class="col-3">
                <label class="subtitulo-detalle">M&eacute;todo de pago:</label>
            </div>
            <div class="col-3">
                <label class="texto-detalle">@Venta.MetodoPago</label>
            </div>
            <div class="col-3">
                <label class="subtitulo-detalle total">Total:</label>
            </div>
            <div class="col-3">
                <label class="texto-detalle total">$@Venta.Total.ToString("N2")</label>
            </div>
        </div>

        @* Monto recibido y Vuelto*@
        <div class="row align-items-center pb-3">
            <div class="col-3">
                <label class="subtitulo-detalle">Monto recibido:</label>
            </div>
            <div class="col-3">
                <label class="texto-detalle">$@Venta.MontoRecibido.ToString("N2")</label>
            </div>
            <div class="col-3">
                <label class="subtitulo-detalle">Vuelto:</label>
            </div>
            <div class="col-3">
                <label class="texto-detalle">$@Venta.Vuelto.ToString("N2")</label>
            </div>
        </div>
    </div>

    <div class="row justify-content-center pt-3">
        <div class="col-2 text-center">
            <a class="boton boton-volver" href="/Ventas/Index">Volver</a>
        </div>
        <div class="col-2 text-center">
            <a class="boton boton-modificar" href="/Ventas/Edit/@VentaId">Modificar</a>
        </div>
        <div class="col-2">
            <button class="boton boton-eliminar" @onclick="Eliminar">Eliminar</button>
        </div>
    </div>
    
    
</div>

@code {
    [Parameter]
    public int VentaId { get; set; }

    public Ventas Venta { get; set; } = new Ventas();

    protected override async Task OnInitializedAsync()
    {
        Venta = await ventasServices.Buscar(VentaId);
    }

    private async Task Eliminar()
    {
        bool eliminado = await ventasServices.Eliminar(VentaId);
        if (eliminado)
        {
            Console.WriteLine("Se ha eliminado la venta correctamente!");
            navigationManager.NavigateTo("/Ventas/Index");
        }
        else
        {
            Console.WriteLine("Ha ocurrido un error al eliminar la venta.");
        }
    }
}
