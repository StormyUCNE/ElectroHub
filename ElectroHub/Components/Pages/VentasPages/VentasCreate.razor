@page "/Ventas/Create";

@rendermode InteractiveServer
@inject VentasService ventasServices;
@inject ProductosService productosService;

<PageTitle>VentasCreate</PageTitle>

<div class="container">
    <label class="titulo">Nueva venta</label>
    <hr />

    @* Agregar producto *@
    <div class="row align-items-center">
        <div class="col-5">
            <div class="input-container">
                <div class="img-container">
                    <img class="" src="/VentasSVG/Search.svg" width="30" height="30" />
                </div>
                <input type="number" placeholder="Agregar producto..." @bind-value="CodigoProducto" />
            </div>
        </div>
        <div class="col-3">
            <button class="boton boton-agregar" type="button" @onclick="AgregarDetalle">Agregar producto</button>
        </div>
    </div>

    @* Tabla de productos *@
    <div class="table-responsive gradient-border-transparent">
        <table>
            <thead>
                <tr>
                    <th>C&oacute;digo</th>
                    <th>Descripci&oacute;n</th>
                    <th>Categor&iacute;a</th>
                    <th>Cantidad</th>
                    <th>Precio</th>
                    <th>ITBIS</th>
                    <th>Subtotal</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var detalle in ListaDetallesVenta)
                {
                    <tr>
                        <td>@detalle.ProductoId</td>
                        <td>@detalle.Descripcion</td>
                        <td>@detalle.Categoria.Nombre</td>
                        <td>
                            <div class="input-container input-cantidad">
                                <input type="text" @bind-value="detalle.Cantidad" />
                            </div>
                        </td>
                        <td>$@detalle.Precio</td>
                        <td>$@detalle.Itbis</td>
                        <td>$@detalle.Subtotal</td>
                        <td>
                            <a @onclick="() => EliminarDetalle(detalle)">
                                <svg  xmlns="http://www.w3.org/2000/svg" height="48px" viewBox="0 -960 960 960" width="48px" fill="#D00707"><path d="M261-120q-24.75 0-42.37-17.63Q201-155.25 201-180v-570h-41v-60h188v-30h264v30h188v60h-41v570q0 24-18 42t-42 18H261Zm438-630H261v570h438v-570ZM367-266h60v-399h-60v399Zm166 0h60v-399h-60v399ZM261-750v570-570Z" /></svg>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!ListaDetallesVenta.Any())
        {
            <div class="text-center p-3">
                <p class="text-white">No hay productos agregados a la venta</p>
            </div>
        }
    </div>

    <div class="neon-card neon-box-style mt-3">
        <label class="titulo">Detalle</label>

        @* Fecha y subtotal *@
        <div class="row align-items-center pb-3">
            <div class="col-3">
                <label class="subtitulo-detalle">Fecha:</label>
            </div>
            <div class="col-3">
                <label class="texto-detalle">@Venta.Fecha</label>
            </div>

            <div class="col-3">
                <label class="subtitulo-detalle">Subtotal:</label>
            </div>
            <div class="col-3">
                <label class="texto-detalle">$@Venta.Subtotal.ToString("N2")</label>
            </div>
        </div>

        @* Vendedor y descuento aplicado *@
        <div class="row align-items-center pb-3">
            <div class="col-3">
                <label class="subtitulo-detalle">Vendedor:</label>
            </div>
            <div class="col-3">
                <label class="texto-detalle">Luis Fonsi</label>
            </div>
            <div class="col-3">
                <label class="subtitulo-detalle">Desc. Aplicado:</label>
            </div>
            <div class="col-3">
                <label class="texto-detalle">$@Venta.DescuentoAplicado.ToString("N2")</label>
            </div>
        </div>

        @* Descuento y ITBIS *@
        <div class="row align-items-center pb-3">
            <div class="col-3">
                <label class="subtitulo-detalle">Descuento:</label>
            </div>
            <div class="col-3">
                <div class="input-container">
                    <div class="img-container">
                        <img class="" src="/VentasSVG/Discount.svg" width="20" height="20" />
                    </div>
                    <input type="number" @bind-value="@Venta.Descuento" min="0" max="100" step="0.01" />
                </div>
            </div>
            <div class="col-3">
                <label class="subtitulo-detalle">ITBIS:</label>
            </div>
            <div class="col-3">
                <label class="texto-detalle">$@Venta.Itbis.ToString("N2")</label>
            </div>
        </div>

        @* Metodo de pago y Total *@
        <div class="row align-items-center pb-3">
            <div class="col-3">
                <label class="subtitulo-detalle">M&eacute;todo de pago:</label>
            </div>
            <div class="col-3">
                <div class="select-container">
                    <div class="img-container">
                        <img class="" src="/VentasSVG/PaymentMethod.svg" width="20" height="20" />
                    </div>
                    <select @bind="@Venta.MetodoPago">
                        <option value="@MetodosPago.Efectivo">Efectivo</option>
                        <option value="@MetodosPago.Tarjeta_Debito">Tarjeta de d&eacute;bito</option>
                        <option value="@MetodosPago.Tarjeta_Credito">Tarjeta de cr&eacute;dito</option>
                        <option value="@MetodosPago.Cheque">Cheque</option>
                    </select>
                </div>
            </div>
            <div class="col-3">
                <label class="subtitulo-detalle total">Total:</label>
            </div>
            <div class="col-3">
                <label class="texto-detalle total">$@Venta.Total.ToString("N2")</label>
            </div>
        </div>

        @* Monto recibido y Vuelto*@
        <div class="row align-items-center pb-3">
            <div class="col-3">
                <label class="subtitulo-detalle">Monto recibido:</label>
            </div>
            <div class="col-3">
                <div class="input-container">
                    <div class="img-container">
                        <img class="" src="/VentasSVG/MoneyBag.svg" width="20" height="20" />
                    </div>
                    <input type="number" @bind-value="Venta.MontoRecibido" />
                </div>
            </div>
            <div class="col-3">
                <label class="subtitulo-detalle">Vuelto:</label>
            </div>
            <div class="col-3">
                <label class="texto-detalle">$@Venta.Vuelto.ToString("N2")</label>
            </div>
        </div>
    </div>

    <div class="row justify-content-center pt-3">
        <div class="col-2">
            <a class="boton boton-volver" href="/Ventas/Index">Volver</a>
        </div>
        <div class="col-2">
            <button class="boton boton-finalizar">Finalizar venta</button>
        </div>
        <div class="col-2">
            <button class="boton boton-limpiar">Limpiar</button>
        </div>
    </div>
</div>

@code {
    public Ventas Venta { get; set; } = new Ventas();
    public List<DetallesVentas> ListaDetallesVenta { get; set; } = new List<DetallesVentas>();
    public int? CodigoProducto { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Venta.DetallesVentas = ListaDetallesVenta;
    }

    public async Task AgregarDetalle()
    {
        if (CodigoProducto.HasValue && CodigoProducto.Value > 0)
        {
            Console.WriteLine("\n" + CodigoProducto + "\n");
            var producto = await productosService.Buscar(CodigoProducto.Value);

            if (producto == null || producto.Eliminado)
            {
                Console.WriteLine("\nProducto no existe o eliminado\n");
                return;
            }

            var detalleExistente = ListaDetallesVenta.FirstOrDefault(d => d.ProductoId == CodigoProducto);

            if (detalleExistente != null)
            {
                // Si ya existe, aumentar la cantidad
                detalleExistente.Cantidad++;

                // Actualizar subtotal del detalle
                detalleExistente.Subtotal = detalleExistente.Precio * detalleExistente.Cantidad;
            }
            else
            {
                // Crear nuevo detalle usando el método del service
                var nuevoDetalle = await ventasServices.CrearDetalleVenta(CodigoProducto.Value, 1);

                // Asignar la categoría correctamente
                if (producto.Categorias != null)
                {
                    nuevoDetalle.Categoria = producto.Categorias;
                }

                Console.WriteLine("\nDetalle agregado:" + nuevoDetalle.Productos.Nombre + "\n");
                ListaDetallesVenta.Add(nuevoDetalle);
            }

            // Actualizar la venta con los nuevos detalles
            Venta.DetallesVentas = ListaDetallesVenta;

            // Recalcular todos los totales
            Venta = ventasServices.CalcularTotales(Venta);

            // Limpiar el código después de agregar
            CodigoProducto = null;
        }
    }

    private void EliminarDetalle(DetallesVentas detalle)
    {
        ListaDetallesVenta.Remove(detalle);
        Venta = ventasServices.CalcularTotales(Venta);
        //Venta.DetallesVentas = ListaDetallesVenta;
    }
}
