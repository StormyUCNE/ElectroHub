@page "/Cuentas"
@using Microsoft.AspNetCore.Identity
@inject AdministradorCuentasService administradorCuentasService
@inject IJSRuntime JS
@rendermode InteractiveServer
<PageTitle>Cuentas</PageTitle>
<div class="cuentas-container">
    <nav>
        <span>Aministración de Cuentas</span>
    </nav>
    <hr />

    @*Filtros*@
    <section class="filter-container">
        <section class="input-container">
            <div class="form-field">
                <input type="text" placeholder="Buscar usuario..." @oninput="Buscar" />
            </div>
        </section>
    </section>

    @*Tabla*@
    <section class="table-section">
        <div class="table-responsive table-containaer">
            <table class="gradient-border-transparent">
                <thead>
                    <tr>
                        <th>Nombre Usuario</th>
                        <th>Email</th>
                        <th>Rol</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in CuentasPaginadas)
                    {
                        <tr>
                            <td>@u.UserName</td>
                            <td>@u.Email</td>
                            <td>
                                <InputSelect @bind-Value="@u.Rol" @bind-Value:after="() => CambiarRole(u, u.Rol)" class="form-select">
                                    @foreach(var rol in ListaRoles)
                                    {
                                        <option value="@rol.Name">@rol.Name</option>
                                    }
                                </InputSelect>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="pagination-container">
            <div class="pagination">
                <img src="/ProductosSVG/NavigationFlechas.svg" alt="Prev" @onclick="PaginaAnterior" disabled="@(paginaActual == 1)" class="@(paginaActual == 1 ? "opacity-25" : "opacity-100")" />
                <span>@paginaActual | @TotalPaginas</span>
                <img src="/ProductosSVG/RigthNav.svg" alt="Next" @onclick="PaginaSiguiente" disabled="@(paginaActual == TotalPaginas)" class="@(paginaActual == TotalPaginas ? "opacity-25" : "opacity-100")" />
            </div>
        </div>
    </section>
</div>

@code{
    public List<UsuariosRoles> ListaUsuarios = new();
    public List<UsuariosRoles> ListaUsuariosOriginal = new();
    public List<IdentityRole> ListaRoles = new List<IdentityRole>();

    protected override async Task OnInitializedAsync()
    {
        ListaUsuariosOriginal = await administradorCuentasService.Listar();
        ListaUsuarios = ListaUsuariosOriginal.ToList();
        ListaRoles = await administradorCuentasService.ListarRoles();
    }

    //Pagination Valores
    private int paginaActual = 1;
    private int registrosPorPagina = 5;
    private int TotalPaginas =>
   (int)Math.Ceiling((double)ListaUsuarios.Count / registrosPorPagina);
    private IEnumerable<UsuariosRoles> CuentasPaginadas =>
         ListaUsuarios
             .Skip((paginaActual - 1) * registrosPorPagina)
             .Take(registrosPorPagina);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            int width = await JS.InvokeAsync<int>("getWindowWidth");
            int height = await JS.InvokeAsync<int>("getWindowHeight");

            int espacioFijo = 220;
            int altoDisponible = height - espacioFijo;

            int altoPorFila = 72;
            int filas = altoDisponible / altoPorFila;

            if (width < 576)
                registrosPorPagina = Math.Clamp(filas, 4, 7);
            else if (width < 768)
                registrosPorPagina = Math.Clamp(filas, 6, 9);
            else if (width < 992)
                registrosPorPagina = Math.Clamp(filas, 8, 12);
            else if (width < 1200)
                registrosPorPagina = Math.Clamp(filas, 4, 18);
            else
                registrosPorPagina = Math.Clamp(filas, 5, 25);
            StateHasChanged();
        }
    }
    private void PaginaAnterior()
    {
        if (paginaActual > 1)
            paginaActual--;
    }

    private void PaginaSiguiente()
    {
        if (paginaActual < TotalPaginas)
            paginaActual++;
    }

    public async Task CambiarRole(UsuariosRoles user, string nuevoRol)
    {
        user.Rol = nuevoRol;
        await administradorCuentasService.CambiarRol(user.UserId, nuevoRol);
        ListaUsuarios = await administradorCuentasService.Listar();
    }

    private async Task Buscar(ChangeEventArgs name)
    {
        var value = name.Value.ToString();
        if (!string.IsNullOrWhiteSpace(value))
        {
            ListaUsuarios = ListaUsuariosOriginal
                .Where(user =>
                    user.UserName.Contains(value, StringComparison.OrdinalIgnoreCase) ||
                    user.Email.Contains(value, StringComparison.OrdinalIgnoreCase) ||
                    user.Rol.Contains(value, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
        else
        {
            ListaUsuarios = ListaUsuariosOriginal.ToList();
        }    
    }
}