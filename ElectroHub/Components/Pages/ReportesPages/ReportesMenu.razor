@page "/Reportes"
@using System.Globalization
@using ElectroHub.Models
@using ElectroHub.Services
@rendermode InteractiveServer
@inject VentasService VentasService
@inject CategoriasService CategoriasService
@inject ExportarReportesService ExportService
@inject IJSRuntime JSRuntime

<div class="dashboard-wrapper">
	<header class="header">
		<h1>Reportes de Ventas</h1>
		<button class="btn-primary" @onclick="AbrirModalExportar"><span>⬇</span> Exportar Reporte</button>
	</header>

	<div class="filters-container neon-box-style">
		<div class="filter-group">
			<label>Rango de Fecha</label>
			<div class="input-wrapper date-range-inputs">
				<span>📅</span>
				<input type="date" @bind="FechaInicio" @bind:after="AplicarFiltros" class="clean-input date-input" />
				<span> - </span>
				<input type="date" @bind="FechaFin" @bind:after="AplicarFiltros" class="clean-input date-input" />
			</div>
		</div>
		<div class="filter-group" style="margin-left: 2rem;">
			<label>Categoría</label>
			<select class="clean-input" @bind="CategoriaSeleccionada" @bind:after="AplicarFiltros">
				<option value="Todas">Todas las categorías</option>
				@if (CategoriasDisponibles != null)
				{
					@foreach (var cat in CategoriasDisponibles)
					{
						<option value="@cat.Nombre">@cat.Nombre</option>
					}
				}
			</select>
		</div>
	</div>

	<div class="main-grid">
		<section class="neon-card neon-box-style left-column-card">
			<div class="card-header">
				<h3>Ventas Recientes</h3>
				<p>Historial detallado de transacciones</p>
			</div>
			<div class="table-container">
				<table class="custom-table">
					<thead>
						<tr>
							<th>Producto</th>
							<th>Categoría</th>
							<th>Fecha</th>
							<th class="text-right">Ingreso</th>
						</tr>
					</thead>
					<tbody>
						@if (VentasPaginadas.Any())
						{
							@foreach (var venta in VentasPaginadas)
							{
								<tr>
									<td>@venta.Producto</td>
									<td>@venta.Categoria</td>
									<td>@venta.Fecha.ToString("dd MMM, yyyy")</td>
									<td class="text-right money-text">@venta.Ingreso.ToString("C", CultureInfo.GetCultureInfo("en-US"))</td>
								</tr>
							}
						}
						else
						{
							<tr><td colspan="4" class="text-center">No hay ventas en este periodo.</td></tr>
						}
					</tbody>
				</table>
			</div>
			<div class="pagination-controls">
				<span class="page-info">Mostrando @VentasPaginadas.Count de @VentasFiltradas.Count</span>
				<div style="display:flex; gap:0.5rem;">
					<button class="btn-arrow" @onclick="PrevPage" disabled="@(PaginaActual <= 1)">‹</button>
					<button class="btn-arrow" @onclick="NextPage" disabled="@(PaginaActual >= TotalPaginas)">›</button>
				</div>
			</div>
		</section>

		<aside class="sidebar">
			<div class="stats-grid">
				<div class="neon-card stat-minimal neon-box-style">
					<span class="stat-badge">Ingresos Totales</span>
					<div class="stat-icon-bg">$</div>
					<div><h2 class="stat-value">@TotalIngresos.ToString("C0", CultureInfo.GetCultureInfo("en-US"))</h2></div>
				</div>
				<div class="neon-card stat-minimal neon-box-style">
					<span class="stat-badge">Total Transacciones</span>
					<div class="stat-icon-bg">🛒</div>
					<div><h2 class="stat-value">@TotalVentasCount</h2></div>
				</div>
			</div>

			<div class="neon-card neon-box-style push-to-bottom" style="margin-top: 1rem;">
				<div class="card-header" style="margin-bottom:0.5rem;"><h3>Productos Top (Por Ingresos)</h3></div>
				<ul class="top-list">
					@if (ProductosTop.Any())
					{
						@foreach (var prod in ProductosTop)
						{
							<li class="top-item">
								<div class="rank-badge">@prod.Rank</div>
								<div style="flex-grow:1; font-size:0.85rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 150px;">@prod.Nombre</div>
								<div style="font-weight:bold; font-size:0.85rem; color: #10b981;">@prod.Precio.ToString("C0", CultureInfo.GetCultureInfo("en-US"))</div>
							</li>
						}
					}
					else
					{
						<li class="top-item" style="justify-content: center; color: #a0a0b0;">Sin datos</li>
					}
				</ul>
			</div>
		</aside>
	</div>
</div>

@if (mostrarModalExportar)
{
	<div class="modal-overlay">
		<div class="modal-content">
			<div class="modal-header">
				<div class="icon-download-container">⬇</div>
				<div>
					<h2>Exportar Reporte</h2>
					<p>Selecciona el formato y opciones</p>
				</div>
			</div>
            
			<div class="modal-body">
				<p class="format-label">Formato de archivo</p>

				<div class="format-option @(formatoSeleccionado == "PDF" ? "selected" : "")" @onclick="@(() => SeleccionarFormato("PDF"))">
					<div class="format-icon" style="background-color: #3b82f6;">📄</div>
					<div class="format-text">
						<strong>PDF</strong><span>Documento con formato completo</span>
					</div>
					<div class="custom-radio @(formatoSeleccionado == "PDF" ? "active" : "")"></div>
				</div>

				<div class="format-option @(formatoSeleccionado == "Excel" ? "selected" : "")" @onclick="@(() => SeleccionarFormato("Excel"))">
					<div class="format-icon" style="background-color: #10b981;">📊</div>
					<div class="format-text">
						<strong>Excel</strong><span>Hoja de cálculo editable</span>
					</div>
					<div class="custom-radio @(formatoSeleccionado == "Excel" ? "active" : "")"></div>
				</div>

				<div class="format-option @(formatoSeleccionado == "CSV" ? "selected" : "")" @onclick="@(() => SeleccionarFormato("CSV"))">
					<div class="format-icon" style="background-color: #6366f1;">📋</div>
					<div class="format-text">
						<strong>CSV</strong><span>Datos sin formato</span>
					</div>
					<div class="custom-radio @(formatoSeleccionado == "CSV" ? "active" : "")"></div>
				</div>
                
				<div class="date-range-box">
					<span>📅 Rango a exportar: @FechaInicio.ToString("dd MMM") - @FechaFin.ToString("dd MMM, yyyy")</span>
					<br /><span style="font-size: 0.75rem; color: #888;">Se exportarán @VentasFiltradas.Count registros.</span>
				</div>
			</div>

			<div class="modal-footer">
				<button class="btn-modal-cancel" @onclick="CerrarModalExportar">Cancelar</button>
				<button class="btn-modal-export" @onclick="ExportarDatos">⬇ Exportar</button>
			</div>
		</div>
	</div>
}

@code {
	private List<VentaReporteDTO> TodasLasVentas = new();
	private List<VentaReporteDTO> VentasFiltradas = new();
	private List<Categorias> CategoriasDisponibles = new();
    
	private DateTime FechaInicio = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);
	private DateTime FechaFin = DateTime.Now;
	private string CategoriaSeleccionada = "Todas";

	private int PaginaActual = 1;
	private int ElementosPorPagina = 8;
	private int TotalPaginas => VentasFiltradas.Any() ? (int)Math.Ceiling((double)VentasFiltradas.Count / ElementosPorPagina) : 1;
	private List<VentaReporteDTO> VentasPaginadas => VentasFiltradas.Skip((PaginaActual - 1) * ElementosPorPagina).Take(ElementosPorPagina).ToList();

	private decimal TotalIngresos => VentasFiltradas.Sum(v => v.Ingreso);
	private int TotalVentasCount => VentasFiltradas.Count;
    
	private class ProductoTopInfo { public int Rank { get; set; } public string Nombre { get; set; } public decimal Precio { get; set; } }
	private List<ProductoTopInfo> ProductosTop = new();

	private bool mostrarModalExportar = false;
	private string formatoSeleccionado = "PDF";

	protected override async Task OnInitializedAsync()
	{
		TodasLasVentas = await VentasService.ObtenerVentasParaReporteAsync();
		CategoriasDisponibles = await CategoriasService.Listar(c => true);
        
		AplicarFiltros();
	}

	private void AplicarFiltros()
	{
		var query = TodasLasVentas.Where(v => v.Fecha.Date >= FechaInicio.Date && v.Fecha.Date <= FechaFin.Date);

		if (CategoriaSeleccionada != "Todas")
		{
			query = query.Where(v => v.Categoria == CategoriaSeleccionada);
		}

		VentasFiltradas = query.OrderByDescending(v => v.Fecha).ToList();
		PaginaActual = 1;
        
		CalcularProductosTop();
	}

	private void CalcularProductosTop()
	{
		ProductosTop = VentasFiltradas
			.GroupBy(v => v.Producto)
			.Select(g => new ProductoTopInfo
			{
				Nombre = g.Key,
				Precio = g.Sum(v => v.Ingreso)
			})
			.OrderByDescending(p => p.Precio)
			.Take(5)
			.Select((p, index) => new ProductoTopInfo
			{
				Rank = index + 1,
				Nombre = p.Nombre,
				Precio = p.Precio
			})
			.ToList();
	}

	private void NextPage() { if (PaginaActual < TotalPaginas) PaginaActual++; }
	private void PrevPage() { if (PaginaActual > 1) PaginaActual--; }

	private void AbrirModalExportar() => mostrarModalExportar = true;
	private void CerrarModalExportar() => mostrarModalExportar = false;
	private void SeleccionarFormato(string formato) => formatoSeleccionado = formato;

	private async Task ExportarDatos()
	{
		Console.WriteLine($"BOTON PRESIONADO. Datos en lista: {VentasFiltradas.Count}");

		var datosSeguros = VentasFiltradas.ToList();
		if (!datosSeguros.Any()) return;

		byte[] archivoBytes = null;
		string nombreArchivo = $"Reporte_{DateTime.Now:yyyyMMdd}";
		string tipoContenido = "";

		if (formatoSeleccionado == "CSV")
		{
			archivoBytes = ExportService.ExportarCSV(datosSeguros);
			nombreArchivo += ".csv";
			tipoContenido = "text/csv";
		}
		else if (formatoSeleccionado == "PDF")
		{
			archivoBytes = ExportService.ExportarPDF(datosSeguros);
			nombreArchivo += ".pdf";
			tipoContenido = "application/pdf";
		}
		else if (formatoSeleccionado == "Excel")
		{
			archivoBytes = ExportService.ExportarExcel(datosSeguros);
			nombreArchivo += ".xlsx";
			tipoContenido = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
		}

		if (archivoBytes != null && archivoBytes.Length > 0)
		{
			await JSRuntime.InvokeVoidAsync("descargarArchivo", nombreArchivo, tipoContenido, Convert.ToBase64String(archivoBytes));
		}
    
		CerrarModalExportar();
	}
}
