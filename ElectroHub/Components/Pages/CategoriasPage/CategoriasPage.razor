@page "/Categorias"
@rendermode InteractiveServer
@inject CategoriasService categoriasService
@inject IJSRuntime JS
<PageTitle>Categorías</PageTitle>
<div class="product-container">
    <nav>
        <span>Categorías</span>
        <AuthorizeView Roles="Admin">
            <Authorized>
                <div class="modal-add-mobile" @onclick:stopPropagation="true">
                    <svg @onclick="() => showAddCategoryModal = true" xmlns="http://www.w3.org/2000/svg" height="48px" viewBox="0 -960 960 960" width="48px" fill="#AA56D7"><path d="M450-120v-330H120v-60h330v-330h60v330h330v60H510v330h-60Z" /></svg>
                </div>
            </Authorized>
        </AuthorizeView>
    </nav>
    <hr />

    @*Filtros*@
    <section class="filter-container">
        <section class="input-container">
            <div class="form-field">
                <input type="text" placeholder="Buscar Categoría..." @oninput="Buscar" />
            </div>
            <div class="date-group">
                <div class="form-field">
                    <input type="date" @bind="FechaInicial" @bind:after="AplicarFiltros" />
                </div>
                <div class="form-field">
                    <input type="date" @bind="FechaFinal" @bind:after="AplicarFiltros" />
                </div>
            </div>
        </section>

        <AuthorizeView Roles="Admin">
            <Authorized>
                @*Botón Agregar*@
                <div class="modal-add" @onclick:stopPropagation="true">
                    <svg @onclick="() => showAddCategoryModal = true" xmlns="http://www.w3.org/2000/svg" height="48px" viewBox="0 -960 960 960" width="48px" fill="#AA56D7"><path d="M450-120v-330H120v-60h330v-330h60v330h330v60H510v330h-60Z" /></svg>
                </div>
            </Authorized>
        </AuthorizeView>
    </section>

    @*Tabla*@
    <section class="table-section">
        <div class="table-responsive table-containaer">
            <table class="gradient-border-transparent">
                <thead>
                    <tr>
                        <th>Categor&iacute;a</th>
                        <th>Nombre</th>
                        <th>Descrici&oacute;n</th>
                        <th>Fecha Registro</th>
                        <th>Opción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in CategoriasPaginadas)
                    {
                        <tr>
                            <td>@c.CategoriaId</td>
                            <td>@c.Nombre</td>
                            <td>@c.Descripcion</td>
                            <td>@c.FechaRegistro.ToString("dd/MM/yyyy")</td>
                            <td @onclick:stopPropagation="true">
                                <div class="btn-container-details" @onclick="() => { CategoriaEditar = c; showCategoryDetailsModal = true; }">
                                    <img src="/ProductosSVG/InfoIcon.svg" alt="Ver Detalle" />
                                    <span>Ver Detalles</span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="pagination-container">
            <div class="pagination">
                <img src="/ProductosSVG/NavigationFlechas.svg" alt="Prev" @onclick="PaginaAnterior" disabled="@(paginaActual == 1)" class="@(paginaActual == 1 ? "opacity-25" : "opacity-100")" />
                <span>@paginaActual | @TotalPaginas</span>
                <img src="/ProductosSVG/RigthNav.svg" alt="Next" @onclick="PaginaSiguiente" disabled="@(paginaActual == TotalPaginas)" class="@(paginaActual == TotalPaginas ? "opacity-25" : "opacity-100")" />
            </div>
        </div>
    </section>
    

    @*Crear Categoría*@
    <div class="modal-overlay @(showAddCategoryModal ? "show" : "")" @onclick="() => showAddCategoryModal = false">
        <div class="modal-details-container @(showAddCategoryModal ? "show" : "")" @onclick:stopPropagation="true">
            <div class="modal-header">
                <img src="/ProductosSVG/DetalleIcon.svg" alt="" />
                <h4>Detalle Categor&iacute;a</h4>
                <img class="cerrar-icon"
                     @onclick="() => showAddCategoryModal = false"
                     @onclick:stopPropagation="true"
                     src="/ProductosSVG/Cerrar.svg"
                     alt="" />
            </div>
            <section>
                <EditForm Model="NuevaCategoria" OnValidSubmit="GuardarCategorias">
                    <DataAnnotationsValidator />
                    <div class="form-inputs">
                        <div>
                            <div class="input-container-item">
                                <label>Nombre:</label>
                                <input type="text" @bind="NuevaCategoria.Nombre" class="form-control" />
                            </div>
                            <ValidationMessage For="() => NuevaCategoria.Nombre" />
                        </div>
                        <div>
                            <div class="input-container-item">
                                <label>Descripción:</label>
                                <input type="text" @bind="NuevaCategoria.Descripcion" class="form-control" />
                            </div>
                            <ValidationMessage For="() => NuevaCategoria.Descripcion" />
                        </div>
                    </div>
                    <AuthorizeView Roles="Admin">
                        <Authorized Context="authContext">
                            <div class="button-container">
                                <div class="register-save-container">
                                    <img src="/ProductosSVG/Save.svg" alt="Guardar" />
                                    <button type="submit">Guardar</button>
                                </div>
                            </div>
                        </Authorized>
                    </AuthorizeView>
                </EditForm>
            </section>
        </div>
    </div>


    @*Detalle Categoría*@
    <div class="modal-overlay @(showCategoryDetailsModal ? "show" : "")" @onclick="() => showCategoryDetailsModal = false">
        <div class="modal-details-container @(showCategoryDetailsModal ? "show" : "")" @onclick:stopPropagation="true">
            <div class="modal-header">
                <img src="/ProductosSVG/DetalleIcon.svg" alt="" />
                <h4>Detalle Categor&iacute;a</h4>
                <img class="cerrar-icon"
                     @onclick="() => showCategoryDetailsModal = false"
                     @onclick:stopPropagation="true"
                     src="/ProductosSVG/Cerrar.svg"
                     alt="" />
            </div>
            <section>
                <EditForm Model="CategoriaEditar" OnValidSubmit="ModificarCategoria">
                    <DataAnnotationsValidator />
                    <div class="form-inputs">
                        <div>
                            <div class="input-container-item">
                                <label>Nombre:</label>
                                <input type="text" @bind="CategoriaEditar.Nombre" class="form-control" />
                            </div>
                            <ValidationMessage For="() => CategoriaEditar.Nombre" />
                        </div>
                        <div>
                            <div class="input-container-item">
                                <label>Descripción:</label>
                                <input type="text" @bind="CategoriaEditar.Descripcion" class="form-control" />
                            </div>
                            <ValidationMessage For="() => CategoriaEditar.Descripcion" />
                        </div>
                        <div>
                            <div class="input-container-item">
                                <label>Fecha:</label>
                                <input type="date" @bind="CategoriaEditar.FechaRegistro" class="form-control" disabled />
                            </div>
                        </div>
                    </div>
                    <AuthorizeView Roles="Admin">
                        <Authorized Context="authContext">
                            <div class="button-container">
                                <div class="register-save-container">
                                    <img src="/ProductosSVG/Save.svg" alt="Guardar" />
                                    <button type="submit">Guardar</button>
                                </div>
                                <div class="register-delete-container">
                                    <img src="/ProductosSVG/Basurero.svg" alt="Eliminar" />
                                    <button type="button" @onclick="() => showDeleteCategoryConfirmationModal = true">Eliminar</button>
                                </div>
                            </div>
                        </Authorized>
                    </AuthorizeView>
                </EditForm>
            </section>
        </div>
    </div>

    <ConfirmacionAgregadoComponente @bind-Mostrar="showCategoryAddedModal" Asunto="La Categoría" Nombre="@NuevaCategoria.Nombre" LimpiarObjeto="LimpiarCampos" />
    <ConfirmacionModificadoComponente @bind-Mostrar="showCategoryUpdatedModal" Asunto="La Categoría" Nombre="@CategoriaEditar.Nombre" LimpiarObjeto="LimpiarCampos" />
    <AvisoEliminarComponente @bind-Mostrar="showDeleteCategoryConfirmationModal" Titulo="Categoría" Nombre="@CategoriaEditar.Nombre" Asunto="La Categoría">
        <div class="register-delete-container">
            <img src="/ProductosSVG/Basurero.svg" alt="Eliminar" />
            <button @onclick="EliminarCategoria">Eliminar</button>
        </div>
    </AvisoEliminarComponente>
    <ErrorNotificacionComponente @bind-Mostrar="showErrorModal" Asunto="No puede Eliminar Categorías en Uso por Productos." />
</div>
@code {
    // Modal para Crear
    private bool showAddModal = false;

    //Modales para las Categorias
    private bool showCategoryAddedModal = false,
    showCategoryUpdatedModal = false,
    showDeleteCategoryConfirmationModal = false,
    showCategoryAdmModal = false,
    showAddCategoryModal = false,
    showCategoryDetailsModal = false,
    showDeleteConfirmationModal = false;

    //Modal de Error
    private bool showErrorModal = false;

    //Filtro para el rango de Fechas
    private DateTime? FechaInicial { get; set; }
    private DateTime? FechaFinal { get; set; }

    //Objetos y Listas
    // CATEGORIAS
    private Categorias NuevaCategoria { get; set; } = new Categorias();
    private Categorias CategoriaEditar { get; set; } = new Categorias();

    public List<Categorias> ListaCategorias = new List<Categorias>();

    //Filtro
    private string Filtro { get; set; } = string.Empty;
    private string textoBusqueda = "";

    //Pagination Valores
    private int paginaActual = 1;
    private int registrosPorPagina = 5;

    private int TotalPaginas =>
    (int)Math.Ceiling((double)ListaCategorias.Count / registrosPorPagina);

    private IEnumerable<Categorias> CategoriasPaginadas =>
        ListaCategorias
            .Skip((paginaActual - 1) * registrosPorPagina)
            .Take(registrosPorPagina);

    protected override async Task OnInitializedAsync()
    {
        ListaCategorias = await categoriasService.Listar(c => c.Eliminado == false);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            int width = await JS.InvokeAsync<int>("getWindowWidth");
            int height = await JS.InvokeAsync<int>("getWindowHeight");

            int espacioFijo = 220;
            int altoDisponible = height - espacioFijo;

            int altoPorFila = 72;
            int filas = altoDisponible / altoPorFila;

            if (width < 576)
                registrosPorPagina = Math.Clamp(filas, 4, 7);
            else if (width < 768)
                registrosPorPagina = Math.Clamp(filas, 6, 9);
            else if (width < 992)
                registrosPorPagina = Math.Clamp(filas, 8, 12);
            else if (width < 1200)
                registrosPorPagina = Math.Clamp(filas, 4, 18);
            else
                registrosPorPagina = Math.Clamp(filas, 5, 25);
            StateHasChanged();
        }
    }

    private async Task LimpiarCampos()
    {
        NuevaCategoria = new Categorias { FechaRegistro = DateTime.Now };
        CategoriaEditar = new Categorias { FechaRegistro = DateTime.Now };
    }

    private async Task GuardarCategorias()
    {
        var creado = await categoriasService.Guardar(NuevaCategoria);

        if (creado)
        {
            showAddCategoryModal = false;
            NuevaCategoria = new Categorias { FechaRegistro = DateTime.Now };
            ListaCategorias = await categoriasService.Listar(c => c.Eliminado == false);
            showCategoryAddedModal = true;
        }
    }

    private void ObtenerCategoria(Categorias c)
    {
        CategoriaEditar = new Categorias
        {
            CategoriaId = c.CategoriaId,
            Nombre = c.Nombre,
            Descripcion = c.Descripcion,
            FechaRegistro = c.FechaRegistro
        };
        showCategoryDetailsModal = true;
    }

    private async Task ModificarCategoria()
    {
        var modificado = await categoriasService.Guardar(CategoriaEditar);
        if (modificado)
        {
            showCategoryDetailsModal = false;
            ListaCategorias = await categoriasService.Listar(c => c.Eliminado == false);
            showCategoryUpdatedModal = true;
        }
    }

    private void GetCategoriaEliminar(Categorias c)
    {
        CategoriaEditar = c;
        showDeleteCategoryConfirmationModal = true;
    }

    private async Task EliminarCategoria()
    {
        var eliminado = await categoriasService.Eliminar(CategoriaEditar.CategoriaId);
        if (eliminado)
        {
            ListaCategorias = await categoriasService.Listar(c => c.Eliminado == false);
            showDeleteCategoryConfirmationModal = false;
            showCategoryDetailsModal = false;
            CategoriaEditar = new Categorias();
        }
        else
        {
            showDeleteCategoryConfirmationModal = false;
            showErrorModal = true;
        }
    }

    public async Task Buscar(ChangeEventArgs e)
    {
        textoBusqueda = e.Value?.ToString() ?? "";
        await AplicarFiltros();
    }

    public async Task AplicarFiltros()
    {
        List<Categorias> listadoFiltrado = await categoriasService.Listar(c => c.Eliminado == false && c.CategoriaId > 0);
        if (FechaInicial.HasValue && FechaFinal.HasValue)
        {
            listadoFiltrado = listadoFiltrado.Where(c => c.FechaRegistro >= FechaInicial && c.FechaRegistro <= FechaFinal).ToList();
        }
        if (!string.IsNullOrWhiteSpace(textoBusqueda))
        {
            listadoFiltrado = listadoFiltrado.Where(c => c.Nombre.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase)).ToList();
        }
        ListaCategorias = listadoFiltrado;
        paginaActual = 1;
    }

    private async Task BuscarCategoria(ChangeEventArgs e)
    {
        var valor = e?.Value?.ToString();
        if (!string.IsNullOrWhiteSpace(valor))
            ListaCategorias = await categoriasService.Listar(c => c.Eliminado == false && c.Nombre.ToString().Contains(valor.ToString()));
        else
            ListaCategorias = await categoriasService.Listar(c => c.Eliminado == false);
    }

    private void PaginaAnterior()
    {
        if (paginaActual > 1)
            paginaActual--;
    }

    private void PaginaSiguiente()
    {
        if (paginaActual < TotalPaginas)
            paginaActual++;
    }
}