@page "/Productos/Eliminados"
@inject NavigationManager navigationManager
@rendermode InteractiveServer
@inject ProductosService productosService
@inject IJSRuntime JS

<PageTitle>Productos Eliminados</PageTitle>
<div class="product-container">
    <div class="back-products" @onclick="VolverAProducto">
        <img src="/GlobalImages/Back.svg" alt="Back To Products" />
        <span>Volver a Productos</span>
    </div>
    <nav>
        <span>Productos Eliminados</span>
    </nav>
    <hr />

    @*Filtros*@
    <section class="filter-container">
        <section class="input-container">
            <div class="form-field">
                <input type="text" placeholder="Buscar Producto..." @oninput="Buscar" />
            </div>

            <div class="select-container">
                <select class="form-field-select" @bind="Filtro">
                    <option value="">Seleccione Filtrar Por</option>
                    <option value="CodigoProducto">Código Producto</option>
                    <option value="Nombre">Nombre</option>
                    <option value="Categoria">Categoría</option>
                    <option value="Proveedor">Proveedor</option>
                    <option value="Estado">Estado</option>
                </select>
            </div>

            <!-- CONTENEDOR NUEVO -->
            <div class="date-group">
                <div class="form-field">
                    <input type="date" @bind="FechaInicial" @bind:after="AplicarFiltros" />
                </div>
                <div class="form-field">
                    <input type="date" @bind="FechaFinal" @bind:after="AplicarFiltros" />
                </div>
            </div>
        </section>
    </section>

    @*Tabla*@
    <section class="table-section">
        <div class="table-responsive table-containaer">
            <table class="gradient-border-transparent">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Stock Mímino</th>
                        <th>Proveedor</th>
                        <th>Categoría</th>
                        <th>Opción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in ProductosPaginados)
                    {
                        <tr>
                            <td>@p.Nombre</td>
                            <td>@p.StockMinimo</td>
                            <td>@p.Proveedores?.NombreEmpresa</td>
                            <td>@p.Categorias?.Nombre</td>
                            <td>
                                <div class="btn-container-details" @onclick="() => ObtenerProducto(p)">
                                    <img src="/GlobalImages/Recover.svg" alt="Ver Detalle" />
                                    <span>Recuperar</span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="pagination-container">
            <div class="pagination">
                <img src="/ProductosSVG/NavigationFlechas.svg" alt="Prev" @onclick="PaginaAnterior" disabled="@(paginaActual == 1)" class="@(paginaActual == 1 ? "opacity-25" : "opacity-100")" />
                <span>@paginaActual | @TotalPaginas</span>
                <img src="/ProductosSVG/RigthNav.svg" alt="Next" @onclick="PaginaSiguiente" disabled="@(paginaActual == TotalPaginas)" class="@(paginaActual == TotalPaginas ? "opacity-25" : "opacity-100")" />
            </div>
        </div>
    </section>

    @*Detalle Producto*@
    <DetalleComponente @bind-Mostrar="showDetailsModal" Titulo="Detalle Productos">
        <EditForm Model="ProductoRecuperar" OnValidSubmit="Recuperar">
            <DataAnnotationsValidator />
            @FormularioProducto(ProductoRecuperar)
            <AuthorizeView Roles="Admin">
                <Authorized Context="authContext">
                    <div class="button-container">
                        <div class="register-save-container">
                            <img src="/GlobalImages/Recover.svg" alt="Guardar" />
                            <button type="submit">Recuperar</button>
                        </div>
                    </div>
                </Authorized>
            </AuthorizeView>
        </EditForm>
    </DetalleComponente>
    <ConfirmacionModificadoComponente @bind-Mostrar="showRecoverProductModal" Asunto="El Producto" Nombre="@ProductoRecuperar.Nombre" Accion="recuperó" LimpiarObjeto="LimpiarCampos" />
    <ErrorNotificacionComponente @bind-Mostrar="showErrorModal" Asunto="No se pudo recuperar el Producto, intente nuevamente." />
</div>

@code {

    public bool showRecoverProductModal = false;

    //Modal de Error
    private bool showErrorModal = false, showDetailsModal = false;

    //Filtro para el rango de Fechas
    private DateTime? FechaInicial { get; set; }
    private DateTime? FechaFinal { get; set; }

    //Objetos y Listas
    // PRODUCTOS
    private Productos ProductoRecuperar { get; set; } = new Productos();
    public List<Productos> ListaProductos = new List<Productos>();

    //Filtro
    private string Filtro { get; set; } = string.Empty;
    private string textoBusqueda = "";

    //Pagination Valores
    private int paginaActual = 1;
    private int registrosPorPagina = 5;

    private int TotalPaginas =>
    (int)Math.Ceiling((double)ListaProductos.Count / registrosPorPagina);

    private IEnumerable<Productos> ProductosPaginados =>
        ListaProductos
            .Skip((paginaActual - 1) * registrosPorPagina)
            .Take(registrosPorPagina);

    protected override async Task OnInitializedAsync()
    {
        ListaProductos = await productosService.Listar(p => p.Eliminado == true && p.ProductoId >0);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            int width = await JS.InvokeAsync<int>("getWindowWidth");
            int height = await JS.InvokeAsync<int>("getWindowHeight");

            int espacioFijo = 220;
            int altoDisponible = height - espacioFijo;

            int altoPorFila = 72;
            int filas = altoDisponible / altoPorFila;

            if (width < 576)
                registrosPorPagina = Math.Clamp(filas, 4, 7);
            else if (width < 768)
                registrosPorPagina = Math.Clamp(filas, 6, 9);
            else if (width < 992)
                registrosPorPagina = Math.Clamp(filas, 8, 12);
            else if (width < 1200)
                registrosPorPagina = Math.Clamp(filas, 4, 18);
            else
                registrosPorPagina = Math.Clamp(filas, 5, 25);
            StateHasChanged();
        }
    }

    private async Task LimpiarCampos(){ProductoRecuperar = new Productos { FechaRegistro = DateTime.Now };}

    private void VolverAProducto() { navigationManager.NavigateTo("/Productos/Index"); }

    private async Task RefrescarLista() { ListaProductos = await productosService.Listar(p => p.Eliminado == true); }


    private void ObtenerProducto(Productos p)
    {
        ProductoRecuperar = new Productos
        {
            ProductoId = p.ProductoId,
            CodigoProducto = p.CodigoProducto,
            Nombre = p.Nombre,
            Descripcion = p.Descripcion,
            CategoriaId = p.CategoriaId,
            PrecioCompra = p.PrecioCompra,
            PrecioVenta = p.PrecioVenta,
            CantidadInventario = p.CantidadInventario,
            StockMinimo = p.StockMinimo,
            ProveedorId = p.ProveedorId,
            EstadosProductos = p.EstadosProductos,
            FechaRegistro = p.FechaRegistro,
            Categorias = p.Categorias,
            Proveedores = p.Proveedores
        };

        showDetailsModal = true;
    }

    public async Task Recuperar()
    {
        var recuperado = await productosService.Recuperar(ProductoRecuperar.ProductoId);
        if (recuperado)
        {
            showRecoverProductModal = true;
            showDetailsModal = false;
            await RefrescarLista();
        }else{
            showErrorModal = true;
        }
    }

    public async Task Buscar(ChangeEventArgs e)
    {
        textoBusqueda = e.Value?.ToString() ?? "";
        await AplicarFiltros();
    }

    public async Task AplicarFiltros()
    {
        List<Productos> listadoFiltrado = await productosService.Listar(p => p.Eliminado == true && p.ProductoId > 0);

        if (FechaInicial.HasValue && FechaFinal.HasValue)
            listadoFiltrado = listadoFiltrado.Where(p => p.FechaRegistro >= FechaInicial && p.FechaRegistro <= FechaFinal).ToList();

        if (!string.IsNullOrWhiteSpace(textoBusqueda))
        {
            if (Filtro == "Nombre")
            {
                listadoFiltrado = listadoFiltrado.Where(p => p.Nombre != null && p.Nombre.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase)).ToList();
            }
            else if (Filtro == "CodigoProducto")
            {
                if (int.TryParse(textoBusqueda, out int Codigo))
                    listadoFiltrado = listadoFiltrado.Where(p => p.CodigoProducto == Codigo).ToList();
            }
            else if (Filtro == "Categoria")
            {
                listadoFiltrado = listadoFiltrado.Where(p => p.Categorias?.Nombre != null &&
                    p.Categorias.Nombre.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase)).ToList();
            }
            else if (Filtro == "Proveedor")
            {
                listadoFiltrado = listadoFiltrado.Where(p => p.Proveedores?.NombreEmpresa != null &&
                    p.Proveedores.NombreEmpresa.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase)).ToList();
            }
            else if (Filtro == "Estado")
            {
                listadoFiltrado = listadoFiltrado.Where(p => p.EstadosProductos.ToString()
                    .Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase)).ToList();
            }
        }
        ListaProductos = listadoFiltrado;
    }

    private void PaginaAnterior()
    {
        if (paginaActual > 1)
            paginaActual--;
    }

    private void PaginaSiguiente()
    {
        if (paginaActual < TotalPaginas)
            paginaActual++;
    }

    private RenderFragment FormularioProducto(Productos productos) => __builder =>
    {
        <section class="edit-form-container">
            <div class="scroll-inputs">

                <div class="input-container-item">
                    <label>Código:</label>
                    <input type="number" @bind="productos.CodigoProducto" class="form-control" disabled/>
                </div>

                <div class="input-container-item">
                    <label>Nombre:</label>
                    <input type="text" @bind="productos.Nombre" class="form-control" disabled/>
                </div>

                <div class="input-container-item">
                    <label>Descripción:</label>
                    <input type="text" @bind="productos.Descripcion" class="form-control" disabled/>
                </div>

                <div class="input-container-item">
                    <label>Categoría:</label>
                    <input type="text" @bind="productos?.Categorias?.Nombre" class="form-control" disabled />
                </div>

                <div class="input-container-item">
                    <label>Precio Compra:</label>
                    <input type="number" @bind="productos.PrecioCompra" class="form-control" disabled />
                </div>

                <div class="input-container-item">
                    <label>Precio Venta:</label>
                    <input type="number" @bind="productos.PrecioVenta" class="form-control" disabled />
                </div>

                <div class="input-container-item">
                    <label>Cantidad:</label>
                    <input type="number" @bind="productos.CantidadInventario" class="form-control" disabled />
                </div>

                <div class="input-container-item">
                    <label>Stock Mínimo:</label>
                    <input type="number" @bind="productos.StockMinimo" class="form-control" disabled />
                </div>

                <div class="input-container-item">
                    <label>Proveedor:</label>
                    <input type="text" @bind="productos?.Proveedores?.NombreEmpresa" class="form-control" disabled />
                </div>

                <div class="input-container-item">
                    <label>Estado:</label>
                    <input type="text" @bind="productos.EstadosProductos" class="form-control" disabled />
                </div>
            </div>
        </section>
    };
}